# API Keys
APOLLO_API_KEY=your_apollo_api_key
FIRECRAWL_API_KEY=your_firecrawl_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-3-7-sonnet-latest
INSTANTLY_API_KEY=your_instantly_api_key

# Campaign Settings
INSTANTLY_CAMPAIGN_ID=your_campaign_id

# Database
DATABASE_URL=file:sqlite.db

# Outreach Settings
DAILY_SEND_LIMIT=50
REQUIRE_APPROVAL=true
EXCLUDED_DOMAINS=competitor.com,example.jp
SLACK_WEBHOOK_URL=your_slack_webhook_url

# SDR Personalization (Set your own product/service info)
SDR_SENDER_NAME=Your Name
SDR_SENDER_TITLE=CEO & Founder at Your Company
SDR_PRODUCT_NAME=Your Product Name
SDR_PRODUCT_DESCRIPTION=Explain what your product does, tech stack, and key benefits.
SDR_PRODUCT_RESTRICTIONS=Any specific target or anti-target (e.g. "Only for React", "Not for WordPress")
