{
	"name": "flow-sales",
	"module": "index.ts",
	"type": "module",
	"version": "1.0.0",
	"description": "Autonomous AI SDR System powered by Bun and Claude 3.5 Sonnet",
	"keywords": [
		"ai-agent",
		"sdr",
		"automation",
		"bun",
		"typescript",
		"claude",
		"hono",
		"drizzle-orm",
		"cold-email"
	],
	"license": "MIT",
	"devDependencies": {
		"@biomejs/biome": "^2.3.15",
		"@types/bun": "^1.3.9",
		"@types/uuid": "^11.0.0",
		"drizzle-kit": "^0.31.9"
	},
	"peerDependencies": {
		"typescript": "^5.9.3"
	},
	"scripts": {
		"dev": "concurrently \"bun dev-server\" \"bun dev-ui\"",
		"dev-server": "bun run src/index.ts",
		"dev-ui": "cd frontend && bun run dev",
		"test": "bun test",
		"test-flow": "bun run src/test-flow.ts",
		"db:push": "bunx drizzle-kit push",
		"lint": "biome lint .",
		"format": "biome format --write .",
		"check": "biome check --write .",
		"type-check": "tsc --noEmit"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.74.0",
		"@libsql/client": "^0.17.0",
		"concurrently": "^9.2.1",
		"drizzle-orm": "^0.45.1",
		"hono": "^4.11.9",
		"uuid": "^11.0.0",
		"zod": "^4.3.6"
	}
}
